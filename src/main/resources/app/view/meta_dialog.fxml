<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.controller.MetaDialogController"
      styleClass="dialog-container"
      spacing="20"
      prefWidth="900"
      prefHeight="600">
    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label fx:id="lblTitulo"
           text="Nova Meta"
           styleClass="dialog-title"/>

    <VBox spacing="15">

        <VBox spacing="6">
            <Label text="Nome da Meta" styleClass="form-label"/>
            <TextField fx:id="txtNome"
                       styleClass="form-field"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Valor Alvo" styleClass="form-label"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="R$" styleClass="currency-symbol"/>
                <TextField fx:id="txtValorAlvo"
                           promptText="0,00"
                           styleClass="form-field, field-currency"
                           HBox.hgrow="ALWAYS"/>
            </HBox>
            <Label fx:id="lblErroValor"
                   styleClass="error-label"
                   visible="false"
                   managed="false"/>
        </VBox>

        <VBox fx:id="boxProgresso"
              spacing="6"
              visible="false"
              managed="false">
            <Label text="Progresso Atual" styleClass="form-label"/>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="Valor Atual" styleClass="info-label-small"/>
                    <Label fx:id="lblValorAtual"
                           text="R$ 0,00"
                           styleClass="info-value"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Restante" styleClass="info-label-small"/>
                    <Label fx:id="lblRestante"
                           text="R$ 0,00"
                           styleClass="info-value"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Progresso" styleClass="info-label-small"/>
                    <Label fx:id="lblProgresso"
                           text="0%"
                           styleClass="info-value, progress-text"/>
                </VBox>
            </HBox>
        </VBox>

    </VBox>

    <Label fx:id="lblErroGeral"
           styleClass="error-label"
           wrapText="true"
           visible="false"
           managed="false"/>

    <VBox VBox.vgrow="ALWAYS"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancelar"
                text="Cancelar"
                styleClass="button-secondary"
                onAction="#handleCancelar"/>
        <Button fx:id="btnSalvar"
                text="Salvar"
                styleClass="button-primary"
                defaultButton="true"
                onAction="#handleSalvar"/>
    </HBox>

</VBox>
