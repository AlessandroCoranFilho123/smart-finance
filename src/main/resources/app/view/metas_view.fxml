<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.controller.MetasViewController"
      styleClass="view-container"
      spacing="20"
      prefWidth="800"
      prefHeight="600">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Minhas Metas" styleClass="view-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnNova" text="+ Nova Meta" styleClass="button-primary"/>
    </HBox>

    <HBox spacing="20" styleClass="stats-bar">
        <padding>
            <Insets top="15" right="20" bottom="15" left="20"/>
        </padding>

        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Total de Metas" styleClass="stat-label"/>
            <Label fx:id="lblTotalMetas" text="0" styleClass="stat-value-large"/>
        </VBox>

        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Metas Concluidas" styleClass="stat-label"/>
            <Label fx:id="lblMetasConcluidas" text="0" styleClass="stat-value-large"/>
        </VBox>

        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Em Andamento" styleClass="stat-label"/>
            <Label fx:id="lblMetasAndamento" text="0" styleClass="stat-value-large"/>
        </VBox>

        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Total Acumulado" styleClass="stat-label"/>
            <Label fx:id="lblTotalAcumulado" text="R$ 0,00" styleClass="stat-value-large"/>
        </VBox>
    </HBox>

    <!-- Busca -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="Buscar:" styleClass="filter-label"/>
        <TextField fx:id="txtBusca"
                   promptText="Digite o nome da meta..."
                   prefWidth="300"
                   styleClass="form-field"/>
        <Button fx:id="btnLimparBusca"
                text="Limpar"
                styleClass="button-secondary"
                visible="false"/>
    </HBox>

    <!-- Abas de filtro -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnTodas" text="Todas" styleClass="button-tab, active"/>
        <Button fx:id="btnAndamento" text="Em Andamento" styleClass="button-tab"/>
        <Button fx:id="btnConcluidas" text="Concluidas" styleClass="button-tab"/>
    </HBox>

    <!-- Lista de metas -->
    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <Label fx:id="lblSecao" text="Todas as Metas" styleClass="section-subtitle"/>

        <!-- ScrollBarPolicy horizontal desativado via CSS: -fx-hbar-policy: never -->
        <ListView fx:id="listMetas"
                  VBox.vgrow="ALWAYS"
                  styleClass="list-metas-full"
                  style="-fx-hbar-policy: never;"/>
    </VBox>
    
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label fx:id="lblTotal" text="Total: 0 metas" styleClass="footer-text"/>
        <Button fx:id="btnFechar" text="Fechar" styleClass="button-secondary"/>
    </HBox>

    <Label fx:id="lblProgresso" visible="false" managed="false"/>

</VBox>
