<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.controller.TransacaoDialogController"
      styleClass="dialog-container"
      spacing="16"
      prefWidth="500"
      prefHeight="600">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <VBox spacing="8">
        <Label text="Tipo" styleClass="form-label"/>
        <HBox spacing="10">
            <fx:define>
                <ToggleGroup fx:id="tipoGroup"/>
            </fx:define>
            <ToggleButton fx:id="btnEntrada"
                          text="Entrada"
                          toggleGroup="$tipoGroup"
                          styleClass="toggle-type, toggle-entrada"
                          selected="true"
                          HBox.hgrow="ALWAYS"
                          maxWidth="Infinity"/>
            <ToggleButton fx:id="btnSaida"
                          text="Saida"
                          toggleGroup="$tipoGroup"
                          styleClass="toggle-type, toggle-saida"
                          HBox.hgrow="ALWAYS"
                          maxWidth="Infinity"/>
        </HBox>
    </VBox>

    <VBox spacing="6">
        <Label text="Valor" styleClass="form-label"/>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="R$" styleClass="currency-symbol"/>
            <TextField fx:id="txtValor"
                       promptText="0,00"
                       styleClass="form-field, field-currency"
                       HBox.hgrow="ALWAYS"/>
        </HBox>
        <Label fx:id="lblErroValor"
               styleClass="error-label"
               visible="false"
               managed="false"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Data" styleClass="form-label"/>
        <DatePicker fx:id="dateTransacao"
                    promptText="Selecione a data"
                    styleClass="form-combo"
                    prefHeight="40"
                    maxWidth="Infinity"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Categoria" styleClass="form-label"/>
        <ComboBox fx:id="cmbCategoria"
                  promptText="Selecione uma categoria"
                  styleClass="form-combo"
                  prefHeight="40"
                  maxWidth="Infinity"/>
    </VBox>

    <VBox fx:id="boxMeta"
          spacing="6"
          visible="false"
          managed="false">
        <Label text="Meta" styleClass="form-label"/>
        <ComboBox fx:id="cmbMeta"
                  promptText="Selecione uma meta"
                  styleClass="form-combo"
                  prefHeight="40"
                  maxWidth="Infinity"/>
        <Label fx:id="lblInfoMeta"
               styleClass="info-label-small"
               wrapText="true"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Comentario" styleClass="form-label"/>
        <TextArea fx:id="txtComentario"
                  promptText="Adicione uma descricao (opcional)"
                  styleClass="form-field, field-textarea"
                  prefRowCount="5"
                  wrapText="true"/>
    </VBox>

    <Label fx:id="lblErroGeral"
           styleClass="error-label"
           wrapText="true"
           visible="false"
           managed="false"/>

    <Label fx:id="lblSaldoAtual" visible="false" managed="false"/>
    <Label fx:id="lblNovoSaldo" visible="false" managed="false"/>
    <VBox fx:id="boxResumo" visible="false" managed="false"/>

    <VBox VBox.vgrow="ALWAYS"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnExcluir"
                text="Excluir"
                styleClass="button-excluir"
                visible="false"
                managed="false"
                onAction="#handleExcluir"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnCancelar"
                text="Cancelar"
                styleClass="button-secondary"
                onAction="#handleCancelar"/>
        <Button fx:id="btnSalvar"
                text="Registrar"
                styleClass="button-primary"
                defaultButton="true"
                onAction="#handleSalvar"/>
    </HBox>

</VBox>
