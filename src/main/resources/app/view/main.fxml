<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800" prefWidth="1300" styleClass="root-container" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.controller.MainController">

    <left>
        <VBox styleClass="sidebar-container">
            <padding>
                <Insets bottom="20" left="20" right="10" top="20"/>
            </padding>

            <VBox alignment="TOP_CENTER" prefWidth="220" spacing="10" styleClass="sidebar" VBox.vgrow="ALWAYS">

                <ImageView fitHeight="120" fitWidth="120" pickOnBounds="false" preserveRatio="true">
                    <image>
                        <Image url="@../icons/app.png"/>
                    </image>
                    <VBox.margin>
                        <Insets bottom="30" top="15"/>
                    </VBox.margin>
                </ImageView>

                <Button fx:id="btnInicio" graphicTextGap="12" maxWidth="Infinity" styleClass="button-sidebar, active">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                                <image>
                                    <Image url="@../icons/inicio.png"/>
                                </image>
                            </ImageView>
                            <Label styleClass="sidebar-text" text="Tela inicial"/>
                        </HBox>
                    </graphic>
                </Button>

                <Button fx:id="btnTransacao" graphicTextGap="12" maxWidth="Infinity" styleClass="button-sidebar">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <ImageView fitHeight="25" fitWidth="25" preserveRatio="true">
                                <image>
                                    <Image url="@../icons/transacao.png"/>
                                </image>
                            </ImageView>
                            <Label styleClass="sidebar-text" text="Transações"/>
                        </HBox>
                    </graphic>
                </Button>

                <Button fx:id="btnMetas" graphicTextGap="12" maxWidth="Infinity" styleClass="button-sidebar">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                                <image>
                                    <Image url="@../icons/meta.png"/>
                                </image>
                            </ImageView>
                            <Label styleClass="sidebar-text" text="Metas"/>
                        </HBox>
                    </graphic>
                </Button>

                <Region VBox.vgrow="ALWAYS"/>

                <Button fx:id="btnTema" graphicTextGap="12" maxWidth="Infinity" styleClass="button-sidebar">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                                <image>
                                    <Image url="@../icons/tema/escuro.png"/>
                                </image>
                            </ImageView>
                            <Label styleClass="sidebar-text" text="Tema"/>
                        </HBox>
                    </graphic>
                </Button>

                <padding>
                    <Insets left="20" right="20"/>
                </padding>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="25" styleClass="main-content">
            <padding>
                <Insets bottom="30" left="20" right="30" top="30"/>
            </padding>

            <VBox spacing="8" styleClass="saldo-banner">
                <padding>
                    <Insets bottom="25" left="30" right="30" top="25"/>
                </padding>

                <Label styleClass="saldo-label" text="Saldo disponível"/>

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label fx:id="lblSaldo" styleClass="saldo-valor" text="R$ 0,00"/>
                </HBox>

                <HBox spacing="30" styleClass="saldo-stats">
                    <VBox spacing="4">
                        <Label styleClass="stat-label" text="Receitas do mês"/>
                        <Label fx:id="lblReceitasMes" styleClass="stat-valor receita" text="R$ 0,00"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label styleClass="stat-label" text="Despesas do mês"/>
                        <Label fx:id="lblDespesasMes" styleClass="stat-valor despesa" text="R$ 0,00"/>
                    </VBox>
                </HBox>
            </VBox>

            <HBox spacing="25" VBox.vgrow="ALWAYS">

                <VBox spacing="15" styleClass="card" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label styleClass="section-title" text="Transações recentes"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button fx:id="btnNovaTransacao" styleClass="button-primary, button-small"
                                text="+ Nova Transação"/>
                    </HBox>

                    <ListView fx:id="listTransacoes" styleClass="list-transacoes" VBox.vgrow="ALWAYS"/>

                    <HBox alignment="CENTER_RIGHT">
                        <Button fx:id="btnVerTodasTransacoes" styleClass="button-link" text="Ver todas →"/>
                    </HBox>
                </VBox>

                <VBox prefWidth="400" spacing="15" styleClass="card">
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label styleClass="section-title" text="Metas"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button fx:id="btnNovaMeta" styleClass="button-primary, button-small" text="+ Nova Meta"/>
                    </HBox>

                    <ListView fx:id="listMetas" styleClass="list-metas, no-scroll" VBox.vgrow="ALWAYS"/>

                    <HBox alignment="CENTER_RIGHT">
                        <Button fx:id="btnVerTodasMetas" styleClass="button-link" text="Ver todas →"/>
                    </HBox>
                </VBox>

            </HBox>
        </VBox>
    </center>

</BorderPane>
